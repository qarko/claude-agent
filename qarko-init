#!/bin/bash
# qarko-init — Claude-code 서버 원-커맨드 복구 shim
# 실제 로직은 dev-env-backup/restore.sh

set -eo pipefail

HOME_DIR="${HOME:-/home/claude}"
BACKUP_DIR="$HOME_DIR/dev-env-backup"
LOG_DIR="$HOME_DIR/.qarko-init/logs"

mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/$(date +%Y-%m-%d).log"

if [ ! -d "$BACKUP_DIR/.git" ]; then
    echo "[qarko-init] dev-env-backup 최초 클론..." | tee -a "$LOG_FILE"
    GIT_AUTH=()
    [ -n "${GITHUB_TOKEN:-}" ] && GIT_AUTH=(-c "http.extraHeader=Authorization: bearer ${GITHUB_TOKEN}")
    git "${GIT_AUTH[@]}" clone --depth=50 https://github.com/qarko/dev-env-backup.git "$BACKUP_DIR" 2>&1 | tee -a "$LOG_FILE" || {
        echo "[qarko-init] dev-env-backup 클론 실패 (GITHUB_TOKEN 필요?)" | tee -a "$LOG_FILE"
        exit 1
    }
fi

if [ ! -x "$BACKUP_DIR/restore.sh" ]; then
    echo "[qarko-init] $BACKUP_DIR/restore.sh 없거나 실행불가" | tee -a "$LOG_FILE"
    exit 2
fi

exec bash "$BACKUP_DIR/restore.sh" "$@"
