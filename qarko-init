#!/bin/bash
# qarko-init — claude-code 서버 원-커맨드 복구
# 사용법: SSH 접속 후 tmux 세션에서 `qarko-init`
#
# 수행 내용:
#   1. dev-env-backup 레포 clone/pull
#   2. restore.sh 실행 (메모리, 프로젝트, CLAUDE.md, 에이전트 복원)
#   3. Claude Code CLI 설치 (npm -g, sudo)
#   4. Bun 설치 (claude 유저 홈)
#   5. 완료 안내

set -e

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log()     { echo -e "${BLUE}[qarko-init]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()     { echo -e "${RED}[ERROR]${NC} $*"; }

HOME_DIR="${HOME:-/home/claude}"
BACKUP_DIR="$HOME_DIR/dev-env-backup"

echo ""
echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
echo -e "${BLUE}║       qarko 개발환경 복구 시작        ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
echo ""

# ── 1. dev-env-backup 동기화 ────────────────────────────────────────────
log "[1/5] dev-env-backup 동기화..."

REPO_URL="https://github.com/qarko/dev-env-backup.git"

# GITHUB_TOKEN은 Authorization 헤더로만 전달 — URL에 박으면 .git/config와 프로세스
# 리스트에 영구 저장되어 볼륨에 남는다.
if [ -n "${GITHUB_TOKEN}" ]; then
    GIT_AUTH=(-c "http.extraHeader=Authorization: bearer ${GITHUB_TOKEN}")
else
    GIT_AUTH=()
fi

if [ -d "$BACKUP_DIR/.git" ]; then
    log "  기존 클론 발견 — pull 실행..."
    git "${GIT_AUTH[@]}" -C "$BACKUP_DIR" pull --ff-only origin main 2>&1 \
        || git "${GIT_AUTH[@]}" -C "$BACKUP_DIR" pull --ff-only origin master 2>&1 \
        || warn "  pull 실패 — 로컬 버전 사용"
else
    log "  dev-env-backup 클론 중..."
    if ! git "${GIT_AUTH[@]}" clone --depth=1 "$REPO_URL" "$BACKUP_DIR"; then
        err "dev-env-backup 클론 실패."
        err "private 레포면 GITHUB_TOKEN 환경변수를 Railway에 설정하세요."
        exit 1
    fi
fi
success "dev-env-backup 준비 완료"

# ── 2. restore.sh 실행 ──────────────────────────────────────────────────
log "[2/5] restore.sh 실행..."
if [ -f "$BACKUP_DIR/restore.sh" ]; then
    bash "$BACKUP_DIR/restore.sh"
    success "메모리/프로젝트/CLAUDE.md 복원 완료"
else
    err "restore.sh를 찾을 수 없습니다: $BACKUP_DIR/restore.sh"
    exit 1
fi

# ── 3. Claude Code CLI 설치 (root 글로벌) ───────────────────────────────
log "[3/5] Claude Code CLI 설치 상태 확인..."
if command -v claude >/dev/null 2>&1; then
    success "claude CLI 이미 설치됨: $(command -v claude)"
else
    log "  npm install -g @anthropic-ai/claude-code (sudo)..."
    if sudo npm install -g @anthropic-ai/claude-code; then
        success "claude CLI 설치 완료"
    else
        warn "claude CLI 설치 실패 — 수동 설치 필요"
    fi
fi

# ── 4. Bun 설치 (claude 유저 홈) ────────────────────────────────────────
log "[4/5] Bun 런타임 설치 상태 확인..."
if [ -x "$HOME_DIR/.bun/bin/bun" ]; then
    success "Bun 이미 설치됨: $HOME_DIR/.bun/bin/bun"
else
    log "  bun.sh 설치 스크립트 실행..."
    if curl -fsSL https://bun.sh/install -o /tmp/bun-install.sh \
        && bash /tmp/bun-install.sh; then
        rm -f /tmp/bun-install.sh
        success "Bun 설치 완료"
    else
        rm -f /tmp/bun-install.sh
        warn "Bun 설치 실패 — 수동 설치 필요"
    fi
fi

# ── 5. tmux 세션 확인 ───────────────────────────────────────────────────
log "[5/5] tmux 세션 상태 확인..."
if command -v tmux &>/dev/null; then
    tmux has-session -t main 2>/dev/null \
        && success "tmux main 세션 실행 중" \
        || { tmux new-session -d -s main -c "$HOME_DIR" && success "tmux main 세션 생성"; }

    if [ -d "$HOME_DIR/qarko-site" ]; then
        tmux has-session -t swiss-vp 2>/dev/null \
            && success "tmux swiss-vp 세션 실행 중" \
            || { tmux new-session -d -s swiss-vp -c "$HOME_DIR/qarko-site" && success "tmux swiss-vp 세션 생성"; }
    fi
fi

echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${GREEN}║           복구 완료!                  ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""
echo "다음 단계:"
echo "  1. tmux attach -t main             # 사장 세션"
echo "  2. claude --dangerously-skip-permissions"
echo ""
echo "  부사장 세션:"
echo "     tmux attach -t swiss-vp"
echo "     cd ~/qarko-site && claude --dangerously-skip-permissions"
echo ""
