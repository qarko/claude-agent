#!/bin/bash
# qarko-init — 전체 개발환경 초기화/복구
# 사용법: qarko-init
#
# SSH 접속 후 tmux main 세션에서 이 명령어 하나로 전체 복원.

set -e

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log()     { echo -e "${BLUE}[qarko-init]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()     { echo -e "${RED}[ERROR]${NC} $*"; }

HOME_DIR="${HOME:-/home/claude}"
BACKUP_DIR="$HOME_DIR/dev-env-backup"

echo ""
echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
echo -e "${BLUE}║       qarko 개발환경 복구 시작        ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
echo ""

# ── 1. dev-env-backup 클론 또는 pull ────────────────────────────────────
log "[1/4] dev-env-backup 동기화..."

if [ -n "${GITHUB_TOKEN}" ]; then
    CLONE_URL="https://${GITHUB_TOKEN}@github.com/qarko/dev-env-backup.git"
else
    CLONE_URL="https://github.com/qarko/dev-env-backup.git"
fi

if [ -d "$BACKUP_DIR/.git" ]; then
    log "  기존 클론 발견 — pull 실행..."
    git -C "$BACKUP_DIR" pull --ff-only origin main 2>&1 || \
        git -C "$BACKUP_DIR" pull --ff-only origin master 2>&1 || \
        warn "  pull 실패 — 로컬 버전 사용"
else
    log "  dev-env-backup 클론 중..."
    git clone --depth=1 "$CLONE_URL" "$BACKUP_DIR" || {
        err "dev-env-backup 클론 실패."
        err "GITHUB_TOKEN 환경변수를 설정하거나 수동으로 클론하세요."
        exit 1
    }
fi
success "dev-env-backup 준비 완료"

# ── 2. restore.sh 실행 ───────────────────────────────────────────────────
log "[2/4] restore.sh 실행..."
cd "$BACKUP_DIR"

if [ -f "restore.sh" ]; then
    bash restore.sh
    success "복원 완료"
else
    err "restore.sh를 찾을 수 없습니다: $BACKUP_DIR/restore.sh"
    exit 1
fi

# ── 3. 메모리 최신화 (qarko/memory 레포가 별도 존재하는 경우) ───────────
log "[3/4] 메모리 최신화 확인..."
MEMORY_DIR="$HOME_DIR/.claude/projects/-home-claude/memory"

if [ -d "$MEMORY_DIR" ]; then
    FILE_COUNT=$(ls "$MEMORY_DIR"/*.md 2>/dev/null | wc -l)
    success "메모리 디렉토리 확인 ($FILE_COUNT개 파일)"
else
    warn "메모리 디렉토리 없음 — restore.sh가 정상 실행되었는지 확인하세요"
fi

# ── 4. tmux 세션 확인 및 안내 ────────────────────────────────────────────
log "[4/4] tmux 세션 상태 확인..."

if command -v tmux &>/dev/null; then
    tmux new-session -d -s main -c "$HOME_DIR" 2>/dev/null && \
        success "tmux main 세션 생성" || \
        success "tmux main 세션 이미 실행 중"

    tmux new-session -d -s swiss-vp -c "$HOME_DIR/qarko-site" 2>/dev/null && \
        success "tmux swiss-vp 세션 생성" || \
        warn "swiss-vp 세션 이미 존재하거나 qarko-site 없음"
fi

echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${GREEN}║           복구 완료!                  ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""
echo "다음 단계:"
echo "  1. tmux attach -t main"
echo "  2. claude --dangerously-skip-permissions 실행"
echo "  3. '개발환경 복구 완료. 메모리 읽고 상태 확인해줘' 입력"
echo ""
